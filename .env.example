# ─── Option A: VPS deployment (recommended) ────────────────────────────────────
# Build with only COMPANY_ID, then run server.js on the same machine as Paperclip.
# The proxy adds auth server-side — no API key exposed to the browser.
#
#   VITE_PAPERCLIP_COMPANY_ID=da1766d2-228a-4b92-a4d3-b8cb6ec0b439 npm run build
#   PAPERCLIP_API_KEY=<your-key> npm run serve

VITE_PAPERCLIP_COMPANY_ID=da1766d2-228a-4b92-a4d3-b8cb6ec0b439

# Leave these empty for VPS proxy mode (server.js handles them server-side):
VITE_PAPERCLIP_API_URL=
VITE_PAPERCLIP_API_KEY=

# ─── server.js env vars (not baked into build) ─────────────────────────────────
PORT=4000
PAPERCLIP_API_URL=http://localhost:3100
PAPERCLIP_API_KEY=your-paperclip-api-key-here

# ─── Option B: Vercel / direct browser access ──────────────────────────────────
# Only works if Paperclip has a public URL reachable from the browser.
# VITE_PAPERCLIP_API_URL=https://your-paperclip-domain.com
# VITE_PAPERCLIP_API_KEY=your-api-key
# VITE_PAPERCLIP_COMPANY_ID=da1766d2-228a-4b92-a4d3-b8cb6ec0b439
