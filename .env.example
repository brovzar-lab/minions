# Paperclip API connection
# Set these in Vercel environment variables to connect to live data
# Without these, the app runs in Demo Mode with hardcoded data

VITE_PAPERCLIP_API_URL=https://your-paperclip-instance.com
VITE_PAPERCLIP_API_KEY=your-api-key-here
VITE_PAPERCLIP_COMPANY_ID=your-company-id-here
